# ── Firebase config (from Firebase Console → Project Settings → Your apps) ──
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Admin config ────────────────────────────────────────────────────────────
# Your Gmail address — this will have super-admin access automatically
VITE_SUPER_ADMIN_EMAIL=youremail@gmail.com

# ── Backend URL ─────────────────────────────────────────────────────────────
# Set to your Render backend URL after deployment
VITE_API_URL=https://chandrastamam-backend.onrender.com
