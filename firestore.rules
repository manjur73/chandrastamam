rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: anyone can write (no login), only authenticated admins can read all
    match /users/{userId} {
      allow write: if true;
      allow read:  if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Admins collection: only existing admins can read/write
    match /admins/{adminId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    function isAdmin(email) {
      return email == '${YOUR_SUPER_ADMIN_EMAIL}'
          || exists(/databases/$(database)/documents/admins/$(email.replace('@','_').replace('.','_')));
    }
  }
}
